{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "ignorePatterns": [
    "src/payload-types.ts",
    "src/migrations/**",
    "src/collections/collection-template.ts",
    "**/*.scss",
    "**/*.css"
  ],
  "ignoreDependencies": [
    "node_modules",
    "@libsql/client",
    "libsql",
    "@react-email/preview-server",
    "require-in-the-middle",
    "import-in-the-middle",
    "eslint-config-next",
    "eslint-config-prettier",
    "@next/eslint-plugin-next",
    "eslint-plugin-react-hooks",
    "tailwindcss-animate"
  ],
  "ignoreExportsUsedInFile": true,
  "duplicates": {
    "ignore": ["**/weather/stations/**"]
  },
  "audit": {
    "healthBaseline": "fallow-baselines/health.json"
  },
  "ignoreExports": [
    {
      "file": "src/components/ui/**",
      "exports": ["*"]
    },
    {
      "file": "src/app/(payload)/admin/**",
      "exports": ["*"]
    },
    {
      "file": "src/collections/GlobalRoles/index.ts",
      "exports": ["*"]
    },
    {
      "file": "src/collections/Roles/index.ts",
      "exports": ["*"]
    }
  ],
  "rules": {
    "unused-files": "error",
    "unused-exports": "error",
    "unused-types": "error",
    "unused-dependencies": "error",
    "unresolved-imports": "error",
    "unlisted-dependencies": "error",
    "circular-dependencies": "warn",
    "duplicate-exports": "warn"
  }
}
