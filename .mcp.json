{
  "mcpServers": {
    "avyweb-payload-local": {
      "type": "http",
      "url": "http://localhost:3000/api/mcp",
      "headers": {
        "Authorization": "Bearer ${AVYWEB_MCP_API_KEY_LOCAL}"
      }
    },
    "avyweb-payload-prod": {
      "type": "http",
      "url": "https://avy-fx.org/api/mcp",
      "headers": {
        "Authorization": "Bearer ${AVYWEB_MCP_API_KEY_PROD}"
      }
    }
  }
}
